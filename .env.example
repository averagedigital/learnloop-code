# Секреты не хранить в репозитории.
# Эти переменные нужны будущему backend/proxy для серверных запросов к AI-провайдерам.

OPENAI_API_KEY=
OPENAI_ADMIN_KEY=
OPENROUTER_API_KEY=
YANDEX_AI_STUDIO_API_KEY=
YANDEX_AI_STUDIO_FOLDER_ID=
YANDEX_AI_STUDIO_BASE_URL=https://ai.api.cloud.yandex.net/v1

# Значения моделей пользователь выбирает сам в интерфейсе или backend-конфиге.
# Примеры намеренно не заданы, чтобы не хардкодить конкретную модель.
OPENAI_MODEL=
OPENROUTER_MODEL=
YANDEX_AI_STUDIO_MODEL=

# External Judge0-compatible sandbox for /api/execute.
JUDGE0_BASE_URL=
JUDGE0_PYTHON_LANGUAGE_ID=71
SANDBOX_CPU_TIME_SEC=2
SANDBOX_WALL_TIME_SEC=5
SANDBOX_MEMORY_KB=262144
SANDBOX_MAX_PROCESSES=1
SANDBOX_NETWORK_ENABLED=false

PERSONALITY_PATH=/data/personality.md

# Persistent app data.
# Set CODELEARN_SEED_DEV_DATA=true only for local/dev bootstrap.
CODELEARN_ENV_PATH=./.env
CODELEARN_DB_PATH=./data/codelearn.sqlite
CODELEARN_SEED_DEV_DATA=false

# Local workspace/agent runtime.
CODELEARN_WORKSPACE_ROOT=./workspace
CODELEARN_WORKSPACE_MOUNT=./workspace
CODELEARN_WORKSPACE_CONTAINER_PATH=/workspaces
CODE_SERVER_PORT=8080
OPENHANDS_PORT=3000
OPENHANDS_LLM_MODEL=
FALKORDB_PORT=6379
GRAPH_MEMORY_PORT=8008
GRAPH_MEMORY_URL=http://127.0.0.1:8008
GRAPHITI_LLM_PROVIDER=auto
GRAPHITI_STRUCTURED_OUTPUT_MODE=json_object
YANDEX_GRAPHITI_MODEL=
YANDEX_GRAPHITI_SMALL_MODEL=
YANDEX_GRAPHITI_EMBEDDING_URL=https://llm.api.cloud.yandex.net/foundationModels/v1/textEmbedding
YANDEX_GRAPHITI_EMBEDDING_MODEL=
YANDEX_GRAPHITI_EMBEDDING_DIM=256
YANDEX_GRAPHITI_MAX_TOKENS=4096
WORKSPACE_RUNTIME_URL=http://127.0.0.1:8080
AGENT_RUNTIME_URL=http://127.0.0.1:3000
